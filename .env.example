# Environment Variables for Ariyalur Geology Website Backend
# 
# SETUP INSTRUCTIONS:
#   1. Copy this file: cp .env.example .env
#   2. Fill in real values from your Supabase project dashboard
#   3. NEVER commit the .env file to Git (it is already in .gitignore)
#   4. Add these variables in your Vercel project dashboard under Settings > Environment Variables

# ---------------------------------------------------------------
# SUPABASE CONFIGURATION
# Get these from: https://supabase.com → Your Project → Settings → API
# ---------------------------------------------------------------

# Your Supabase project URL  (e.g., https://xyzcompany.supabase.co)
SUPABASE_URL=https://your-project-id.supabase.co

# Supabase anonymous/public key  (safe for browser use)
SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Supabase service role key  (SECRET – server-side only, never expose in browser code)
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# ---------------------------------------------------------------
# OPTIONAL: VERCEL DEPLOYMENT INFO
# These are automatically set by Vercel during deployment
# ---------------------------------------------------------------

# The public URL where the backend API is deployed
# VERCEL_URL is set automatically by Vercel; override here if using a custom domain
# API_BASE_URL=https://your-custom-domain.com

# ---------------------------------------------------------------
# OPTIONAL: NOTIFICATION SETTINGS
# Configure email notifications for new fossil submissions (future use)
# ---------------------------------------------------------------

# NOTIFICATION_EMAIL=natgeolo5@gmail.com
