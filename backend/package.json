{
  "name": "ariyalur-geology-backend",
  "version": "1.0.0",
  "description": "Backend API for Ariyalur Geology Website - Registration, Fossil Upload, and Details",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test": "jest --coverage",
    "test:unit": "jest --testPathPattern=tests/(api|email|upload).test.js --coverage",
    "test:integration": "jest --testPathPattern=tests/integration.test.js",
    "test:database": "jest --testPathPattern=tests/database.test.js",
    "test:performance": "jest --testPathPattern=tests/performance.test.js",
    "lint": "eslint . --ext .js",
    "lint:fix": "eslint . --ext .js --fix",
    "format": "prettier --check .",
    "format:fix": "prettier --write ."
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.39.0",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "helmet": "^7.1.0",
    "multer": "^2.1.1",
    "nodemailer": "^8.0.4",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "@jest/globals": "^29.7.0",
    "eslint": "^8.56.0",
    "jest": "^29.7.0",
    "nodemon": "^3.0.2",
    "prettier": "^3.1.1",
    "supertest": "^7.1.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "geology",
    "ariyalur",
    "fossils",
    "api",
    "supabase"
  ],
  "author": "Ariyalur Geology Team",
  "license": "MIT"
}
